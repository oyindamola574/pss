# ============================================================
# Protocol Security Scout — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Solana Network ───────────────────────────────────────────
# Cluster to use: devnet | testnet | mainnet-beta
CLUSTER=devnet

# Solana RPC endpoint (use a dedicated node for production)
RPC_URL=https://api.devnet.solana.com

# ── Treasury / Vault ─────────────────────────────────────────
# The public key of your fee-collection wallet (Devnet)
# Users pay scan fees to this address
VAULT_ADDRESS=HUXqL7fN3eR2MvL1U8K9vGj98bX9N18L2X3y4z5w6a7

# ── Server ───────────────────────────────────────────────────
PORT=5000

# ── Scan Pricing (SOL) ───────────────────────────────────────
# General audit base fee
SCAN_FEE_GENERAL=0.02

# Custom agent: base + per-threat surcharge
SCAN_FEE_CUSTOM_BASE=0.01
SCAN_FEE_CUSTOM_PER_THREAT=0.005

# ── Frontend ─────────────────────────────────────────────────
# Must match the backend URL when deployed
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000
